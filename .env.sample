DATABASE_URL=
AUTH_SECRET=
AUTH_URL=
AWS_REGION=
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# ローカル/CI/E2E専用。/api/test/cleanup 等のテスト専用エンドポイントを有効化する。
# 本番環境には絶対に設定しないこと。
ENABLE_TEST_ENDPOINTS=
# ローカル/CI/E2E専用。bcryptのハッシュ化コスト（デフォルト12）を下げ、
# パスワードハッシュ比較によるCPU負荷（E2Eのフレーク要因）を減らす。
# 本番環境には絶対に設定しないこと（コストを下げるとパスワードの総当たり耐性が下がる）。
BCRYPT_COST=
# パフォーマンステスト（.env.perf）専用。Playwrightのwebserverを無効化し、
# perf:start済みのサーバーに直接接続させる（開発DBに誤って接続するのを防ぐ）。
PERF=
