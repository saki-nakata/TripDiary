    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.101.2",
    "bcryptjs": "^3.0.3",
    "leaflet": "^1.9.4",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "react-leaflet": "^5.0.0",
